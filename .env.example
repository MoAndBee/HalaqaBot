# Telegram Bot Token
# Get your token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Forward Chat ID
# The chat ID where messages will be forwarded to retrieve author information
# This can be your personal chat ID or a dedicated channel/group
FORWARD_CHAT_ID=-5055699596

# Groq API Key
# Get your API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Auto-reaction emoji (optional)
# Emoji to use when bot auto-reacts to messages with names
# Options: ❤, 👍, 👎, 🔥, 🥰
AUTO_REACTION_EMOJI=❤

# Convex Configuration
# Server-side URL for the local Convex backend (default: http://localhost:3210)
# or your Convex cloud deployment URL
CONVEX_URL=http://localhost:3210
# Client-side URL (used by Vite/browser - must be prefixed with VITE_)
# Should be the same as CONVEX_URL
VITE_CONVEX_URL=http://localhost:3210

# Telegram Channels
# Primary channel ID (used as forward/seed default)
# CHANNEL_ID=-1001234567890
# All channels to register on startup (comma-separated). Channels are also
# auto-discovered from live traffic; this just guarantees them at boot.
# CHANNEL_IDS=-1001234567890,-1009876543210
